{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://raw.githubusercontent.com/opencustodian/OpenCustodian/main/proofObjects/v.0.0.1/proofObjects.schema.json",
	"title": "OpenCustodian Proof Object",
	"type": "object",
	"description": "OpenCustodian proof object schema.",
	"properties": {
		"$schema": {
            "title": "Schema",
            "type": "string",
            "format": "uri-reference",
			"description": "The schema URL that the proof object should conform to."
        },
        "$comment": {
            "title": "Schema",
            "type": "string",
            "description": "An optional comment string that can be used to document the purpose of the file."
        },
		"type": {
			"title": "Proof type",
			"type": "string",
			"description": "Identifier of the proof standard."
		},
		"uri": {
			"title": "URI",
			"type": "string",
			"description": "URI to the file."
		},
		"fileFormat": {
			"title": "File format",
			"type": "string",
			"description": "Formats for external data file."
		},
		"encoding": {
			"type": "string",
			"description": "Character encoding of the external file."
		},
		"hash": {
			"$ref": "#/$defs/hashValue"
		}
	},
	"required": [
		"type",
		"fileFormat",
		"encoding",
		"hash"
	],
	"additionalProperties": false,
	"$defs": {
		"hashValue": {
			"title": "Hash value",
			"type": "object",
			"description": "Cryptographic hash of the external file for integrity verification.",
			"properties": {
				"algorithm": {
					"type": "string",
					"enum": [
						"sha256"
					],
					"description": "Hash algorithm used."
				},
				"value": {
					"type": "string",
					"pattern": "^[A-Fa-f0-9]{64}$",
					"description": "Hexadecimal hash value."
				}
			},
			"required": [
				"algorithm",
				"value"
			],
			"additionalProperties": false
		}
	}
}