{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/opencustodian/schemas/formats/proof-of-reserves/ocf1.3-token-ledger.schema.json",
  "title": "Proof-of-Reserves Token Ledger",
  "OCF": "1.3",
  "version": "DRAFT",
  "description": "Proof-of-reserves payload for multi-chain token reserves exported as YAML (network -> asset -> addresses).",
  "type": "object",
  "patternProperties": {
    "^[a-z0-9-]+$": {
      "$ref": "#/$defs/network"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "amountLike": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)(?:\\.\\d+)?$"
        },
        {
          "type": "integer",
          "minimum": 0
        }
      ]
    },
    "network": {
      "type": "object",
      "patternProperties": {
        "^[A-Za-z0-9]{2,12}$": {
          "$ref": "#/$defs/asset"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "asset": {
      "type": "object",
      "properties": {
        "addresses": {
          "$ref": "#/$defs/addressMap"
        },
        "total": {
          "$ref": "#/$defs/amountLike"
        }
      },
      "required": [
        "addresses",
        "total"
      ],
      "additionalProperties": false
    },
    "addressMap": {
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "$ref": "#/$defs/addressEntry"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "addressEntry": {
      "type": "object",
      "properties": {
        "balance": {
          "$ref": "#/$defs/amountLike"
        }
      },
      "required": [
        "balance"
      ],
      "additionalProperties": false
    }
  }
}
